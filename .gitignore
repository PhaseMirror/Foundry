# ----------------------------------------------------------------------
# PhaseMirror Unified .gitignore
# ----------------------------------------------------------------------

# Rust artifacts
target/
Cargo.lock
**/*.rs.bk

# Node.js artifacts
node_modules/
dist/
build/
.npm/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Lean artifacts
.lake/
.lake-build/
*.olean
*.ilean
*.c
*.o

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
venv/
env/
.venv/

# Circom / ZK artifacts
*.zkey
*.ptau
*.wasm
*.r1cs
*.sym
*_js/
*_cpp/
pot*/
verification_key.json
public.json
proof.json

# Hardhat / Foundry
cache/
artifacts/
broadcast/
out/
.forge-snapshots/

# OS / Editor artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Temporary / Logs
*.log
*.tmp
*.temp
*.bak

# Explicit allows (if needed)
!contracts/script/
!scripts/
