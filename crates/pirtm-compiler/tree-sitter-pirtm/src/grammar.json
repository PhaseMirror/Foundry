{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "pirtm",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "statement"
      }
    },
    "statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tensor_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "operator_application"
        },
        {
          "type": "SYMBOL",
          "name": "contractivity_assertion"
        }
      ]
    },
    "tensor_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "tensor"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "FIELD",
          "name": "prime_axes",
          "content": {
            "type": "SYMBOL",
            "name": "prime_list"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    },
    "operator_application": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "target",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "|>"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "FIELD",
                  "name": "scaling_factor",
                  "content": {
                    "type": "SYMBOL",
                    "name": "lambda_constant"
                  }
                },
                {
                  "type": "STRING",
                  "value": "*"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "prime_chain",
          "content": {
            "type": "SYMBOL",
            "name": "prime_chain"
          }
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    },
    "contractivity_assertion": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "assert_contractive"
        },
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "FIELD",
          "name": "target",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": ")"
        },
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "FIELD",
          "name": "bound",
          "content": {
            "type": "SYMBOL",
            "name": "float"
          }
        },
        {
          "type": "STRING",
          "value": ";"
        }
      ]
    },
    "prime_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "prime_literal"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "prime_literal"
              }
            ]
          }
        }
      ]
    },
    "prime_chain": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "prime_literal"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "*"
              },
              {
                "type": "SYMBOL",
                "name": "prime_literal"
              }
            ]
          }
        }
      ]
    },
    "prime_literal": {
      "type": "PATTERN",
      "value": "p_[1-9][0-9]*"
    },
    "lambda_constant": {
      "type": "STRING",
      "value": "\\Lambda_m"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "float": {
      "type": "PATTERN",
      "value": "[0-9]+\\.[0-9]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}