{
  "shannon_entropy": [
    { "input": [0.5, 0.5], "expected": 1.0, "note": "fair coin — maximum entropy for 2 outcomes" },
    { "input": [1.0, 0.0], "expected": 0.0, "note": "deterministic — zero entropy" },
    { "input": [0.25, 0.25, 0.25, 0.25], "expected": 2.0, "note": "uniform over 4 — 2 bits" },
    { "input": [0.5, 0.25, 0.125, 0.125], "expected": 1.75, "note": "mixed distribution" }
  ],
  "superposition_entropy": [
    {
      "amplitudes": [
        { "weight": 0.5, "value": "east" },
        { "weight": 0.5, "value": "west" }
      ],
      "expected_entropy": 1.0,
      "within_bound": true,
      "max_bound": 6.0
    },
    {
      "amplitudes": [
        { "weight": 1.0, "value": "north" }
      ],
      "expected_entropy": 0.0,
      "note": "collapsed — single branch"
    }
  ],
  "normalize": [
    { "input": [1, 1, 1, 1], "expected": [0.25, 0.25, 0.25, 0.25] },
    { "input": [2, 1], "expected": [0.6667, 0.3333] },
    { "input": [0, 0], "note": "zero total → equal distribution", "expected": [0.5, 0.5] }
  ],
  "kl_divergence": [
    { "p": [0.5, 0.5], "q": [0.5, 0.5], "expected": 0.0, "note": "identical distributions" },
    { "p": [1.0, 0.0], "q": [0.9, 0.1], "expected_approx": 0.152, "note": "near-deterministic" }
  ],
  "constants": {
    "epsilon": 1e-10,
    "collapse_entropy_max": 6.0,
    "log_base": 2
  }
}
