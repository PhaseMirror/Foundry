\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{recursion-constitution}[2025/10/20 v0.1]

% Typography and math
\RequirePackage{microtype}
\RequirePackage{csquotes}
\RequirePackage{amsmath,amssymb,mathtools}
\RequirePackage{amsthm}

% Lists and tables
\RequirePackage{enumitem}
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{array}

% Cross-referencing
\RequirePackage{hyperref}
\RequirePackage{cleveref}

% Optional glossary for acronyms
\RequirePackage[acronym]{glossaries}

% -------- Hyperref --------
\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  citecolor=blue,
  urlcolor=blue
}

% -------- Numbering --------
\numberwithin{equation}{section}

% -------- Theorem-like structures --------
\theoremstyle{plain}
\newtheorem{article}{Article}
\renewcommand{\thearticle}{\Roman{article}} % Article I, II, ...

\newtheorem{theorem}{Theorem}[article]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{axiom}[theorem]{Axiom}
\newtheorem{assumption}[theorem]{Assumption}
\newtheorem{invariant}[theorem]{Invariant}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{principle}{Principle}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
\newtheorem{critique}{Critique}

% Cleveref names
\crefname{article}{Article}{Articles}
\Crefname{article}{Article}{Articles}
\crefname{theorem}{Theorem}{Theorems}
\crefname{lemma}{Lemma}{Lemmas}
\crefname{axiom}{Axiom}{Axioms}
\crefname{assumption}{Assumption}{Assumptions}
\crefname{invariant}{Invariant}{Invariants}
\crefname{definition}{Definition}{Definitions}
\crefname{principle}{Principle}{Principles}
\crefname{critique}{Critique}{Critiques}

% -------- Operators and macros --------
\DeclareMathOperator{\Tr}{Tr}
\DeclareMathOperator{\Proj}{Proj}
\DeclareMathOperator{\Span}{span}
\DeclareMathOperator{\Ker}{Ker}
\DeclareMathOperator{\Ran}{Ran}
\DeclareMathOperator{\Id}{Id}

\newcommand{\ip}[2]{\left\langle #1,\,#2\right\rangle}
\newcommand{\norm}[1]{\left\lVert #1\right\rVert}
\newcommand{\abs}[1]{\left\lvert #1\right\rvert}
\newcommand{\floor}[1]{\left\lfloor #1\right\rfloor}
\newcommand{\ceil}[1]{\left\lceil #1\right\rceil}
\newcommand{\state}[3]{#1\!\left(#2,#3\right)}
\newcommand{\basis}[1]{\mathcal{B}_{#1}}

% -------- Critique table helper --------
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}
\newenvironment{CritiqueTable}{%
  \begin{longtable}{@{}L{0.12\linewidth}L{0.28\linewidth}L{0.40\linewidth}L{0.20\linewidth}@{}}
  \toprule
  \textbf{ID} & \textbf{Name} & \textbf{Condition} & \textbf{Certificate} \\
  \midrule\endhead}{\bottomrule\end{longtable}}
\newcommand{\critiqueentry}[4]{#1 & #2 & #3 & #4\\}

% -------- Headers (amsart-safe) --------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[RO,LE]{\thepage}
\fancyhead[LO]{\nouppercase{\leftmark}}
\fancyhead[RE]{\nouppercase{\rightmark}}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\makeatletter
\renewcommand{\sectionmark}[1]{\markboth{\thesection\ #1}{}}
\renewcommand{\subsectionmark}[1]{\markright{\thesubsection\ #1}}
\makeatother

% -------- List tuning --------
\setlist[itemize]{leftmargin=2em}
\setlist[enumerate]{leftmargin=2em}
