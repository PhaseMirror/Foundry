  edition      = {2},
  year         = {2012},
  note         = {Standard reference for spectral radius formula, operator norms $\|\cdot\|_2$, $\|\cdot\|_\infty$, and equivalence of matrix norms used in the spectral-radius bound $\rho(\mathbf{G}) \leq \|\mathbf{G}\|_2 < 1$}
}

