{
  "name": "pirtm-lang",
  "displayName": "PIRTM",
  "description": "Language support for the PIRTM compute language",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pirtm",
        "aliases": [
          "PIRTM",
          "pirtm"
        ],
        "extensions": [
          ".pirtm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pirtm",
        "scopeName": "source.pirtm",
        "path": "./syntaxes/pirtm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "pirtm",
        "path": "./snippets.json"
      }
    ]
  }
}
