{
  "Ensemble Declaration": {
    "prefix": "ensemble",
    "body": [
      "ensemble ${1:name} v${2:1.0.0} prime=${3:2};",
      "",
      "$0"
    ],
    "description": "Scaffold a new ensemble"
  },
  "Import Statement": {
    "prefix": "use",
    "body": [
      "use ${1:module} as ${2:alias} with spectral_budget = ${3:0.5};"
    ],
    "description": "Import a module with governance budget"
  },
  "Atom": {
    "prefix": "Ap",
    "body": [
      "Ap(${1:index})"
    ],
    "description": "Governed atom"
  }
}
