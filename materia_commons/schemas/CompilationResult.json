{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompilationResult",
  "type": "object",
  "required": [
    "axioms_clean",
    "compilation_timestamp",
    "pirtm_version",
    "spoliation_risk_level"
  ],
  "properties": {
    "axioms_clean": {
      "type": "boolean"
    },
    "compilation_timestamp": {
      "type": "string"
    },
    "lean_proof_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "pirtm_version": {
      "type": "string"
    },
    "required_retention_days": {
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0.0
    },
    "spoliation_risk_level": {
      "$ref": "#/definitions/SpoliationRiskLevel"
    }
  },
  "definitions": {
    "SpoliationRiskLevel": {
      "type": "string",
      "enum": [
        "Critical",
        "High",
        "Medium",
        "Low"
      ]
    }
  }
}