{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CritiqueResult",
  "type": "object",
  "required": [
    "critique_id",
    "passed"
  ],
  "properties": {
    "critique_id": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "passed": {
      "type": "boolean"
    },
    "reason": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}