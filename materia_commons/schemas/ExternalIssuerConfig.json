{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExternalIssuerConfig",
  "type": "object",
  "required": [
    "active",
    "issuerId",
    "issuerType",
    "uniquenessSaltId"
  ],
  "properties": {
    "active": {
      "type": "boolean"
    },
    "expectedClientId": {
      "type": [
        "string",
        "null"
      ]
    },
    "issuerId": {
      "type": "string"
    },
    "issuerType": {
      "$ref": "#/definitions/IssuerType"
    },
    "jwksUri": {
      "type": [
        "string",
        "null"
      ]
    },
    "oidcIssuerUrl": {
      "type": [
        "string",
        "null"
      ]
    },
    "uniquenessSaltId": {
      "type": "string"
    },
    "vcDid": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "definitions": {
    "IssuerType": {
      "type": "string",
      "enum": [
        "bank",
        "hospital",
        "university",
        "gov",
        "other"
      ]
    }
  }
}