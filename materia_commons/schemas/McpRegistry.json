{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "McpRegistry",
  "type": "object",
  "required": [
    "servers"
  ],
  "properties": {
    "servers": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/McpServerDescriptor"
      }
    }
  },
  "definitions": {
    "McpServerDescriptor": {
      "type": "object",
      "required": [
        "alp_required",
        "args",
        "command",
        "governed",
        "hash",
        "id",
        "name",
        "transport",
        "trust"
      ],
      "properties": {
        "alp_required": {
          "type": "boolean"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "capabilities": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "command": {
          "type": "string"
        },
        "governed": {
          "type": "boolean"
        },
        "hash": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sat_ttl_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "tags": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "transport": {
          "type": "string"
        },
        "trust": {
          "type": "string"
        },
        "warning": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}