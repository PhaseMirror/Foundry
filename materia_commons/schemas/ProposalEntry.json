{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProposalEntry",
  "type": "object",
  "required": [
    "committed_at",
    "delta",
    "multiplicity_effect",
    "proposal_id",
    "rationale"
  ],
  "properties": {
    "committed_at": {
      "type": "string"
    },
    "delta": true,
    "multiplicity_effect": {
      "$ref": "#/definitions/MultiplicityEffect"
    },
    "proposal_id": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    }
  },
  "definitions": {
    "MultiplicityEffect": {
      "type": "object",
      "required": [
        "currentTokenValue",
        "projectedCivicState",
        "projectedTokenValue"
      ],
      "properties": {
        "currentTokenValue": {
          "type": "number",
          "format": "double"
        },
        "projectedCivicState": {
          "type": "number",
          "format": "double"
        },
        "projectedTokenValue": {
          "type": "number",
          "format": "double"
        }
      }
    }
  }
}