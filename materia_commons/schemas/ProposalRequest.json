{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProposalRequest",
  "type": "object",
  "required": [
    "consecutive_failures",
    "contractivity_score",
    "critique_results",
    "drift_rate",
    "kill_switch_active",
    "payload",
    "prime_gates",
    "proposal_id",
    "rationale",
    "state_norm"
  ],
  "properties": {
    "consecutive_failures": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "contractivity_score": {
      "type": "number",
      "format": "double"
    },
    "critique_results": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/CritiqueResult"
      }
    },
    "drift_rate": {
      "type": "number",
      "format": "double"
    },
    "kill_switch_active": {
      "type": "boolean"
    },
    "payload": true,
    "prime_gates": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PrimeGate"
      }
    },
    "proposal_id": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "rollback_anchor_sha": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_norm": {
      "type": "number",
      "format": "double"
    }
  },
  "definitions": {
    "CritiqueResult": {
      "type": "object",
      "required": [
        "critique_id",
        "passed"
      ],
      "properties": {
        "critique_id": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "passed": {
          "type": "boolean"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "PrimeGate": {
      "type": "object",
      "required": [
        "action_name",
        "gate_value"
      ],
      "properties": {
        "action_name": {
          "type": "string"
        },
        "gate_value": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    }
  }
}