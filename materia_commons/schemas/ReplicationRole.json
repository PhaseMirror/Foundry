{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReplicationRole",
  "description": "Role of this Commander node in the replication topology.",
  "oneOf": [
    {
      "type": "string",
      "enum": [
        "primary"
      ]
    },
    {
      "type": "object",
      "required": [
        "replica"
      ],
      "properties": {
        "replica": {
          "type": "object",
          "required": [
            "primary_addr"
          ],
          "properties": {
            "primary_addr": {
              "type": "string"
            }
          }
        }
      },
      "additionalProperties": false
    }
  ]
}