{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SignedAdmissionToken",
  "type": "object",
  "required": [
    "caller_identity",
    "capabilities_granted",
    "constitution_version",
    "expires_at",
    "issued_at",
    "server_binding",
    "signature",
    "signature_scheme",
    "token_id",
    "tool_name"
  ],
  "properties": {
    "caller_identity": {
      "type": "string"
    },
    "capabilities_granted": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constitution_version": {
      "type": "string"
    },
    "expires_at": {
      "type": "integer",
      "format": "int64"
    },
    "issued_at": {
      "type": "integer",
      "format": "int64"
    },
    "server_binding": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "signature_scheme": {
      "type": "string"
    },
    "task_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "token_id": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    }
  }
}