{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UnifiedWitness",
  "type": "object",
  "required": [
    "action_id",
    "compliance_evidence",
    "contractivity_score",
    "execution_receipt",
    "timestamp",
    "veto_status",
    "witness_id"
  ],
  "properties": {
    "action_id": {
      "type": "string"
    },
    "compliance_evidence": {
      "type": "string"
    },
    "contractivity_score": {
      "type": "number",
      "format": "double"
    },
    "execution_receipt": true,
    "p_lineage": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "timestamp": {
      "type": "string"
    },
    "veto_status": {
      "$ref": "#/definitions/VetoStatus"
    },
    "witness_hash": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "witness_id": {
      "type": "string"
    }
  },
  "definitions": {
    "VetoStatus": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "approved",
            "pending"
          ]
        },
        {
          "type": "object",
          "required": [
            "vetoed"
          ],
          "properties": {
            "vetoed": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}