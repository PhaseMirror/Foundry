{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UniquenessAnchor",
  "type": "object",
  "required": [
    "anchorHash",
    "context",
    "issuerId"
  ],
  "properties": {
    "anchorHash": {
      "type": "string"
    },
    "civicProfile": {
      "anyOf": [
        {
          "$ref": "#/definitions/CivicProfile"
        },
        {
          "type": "null"
        }
      ]
    },
    "context": {
      "type": "string"
    },
    "issuerId": {
      "type": "string"
    }
  },
  "definitions": {
    "CivicProfile": {
      "type": "object",
      "required": [
        "agency",
        "integrity",
        "resonance",
        "viability"
      ],
      "properties": {
        "agency": {
          "type": "number",
          "format": "double"
        },
        "integrity": {
          "type": "number",
          "format": "double"
        },
        "resonance": {
          "type": "number",
          "format": "double"
        },
        "viability": {
          "type": "number",
          "format": "double"
        }
      }
    }
  }
}