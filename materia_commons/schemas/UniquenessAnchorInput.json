{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UniquenessAnchorInput",
  "type": "object",
  "required": [
    "context",
    "issuer",
    "subjectId"
  ],
  "properties": {
    "civicProfile": {
      "anyOf": [
        {
          "$ref": "#/definitions/CivicProfile"
        },
        {
          "type": "null"
        }
      ]
    },
    "context": {
      "type": "string"
    },
    "issuer": {
      "$ref": "#/definitions/ExternalIssuerConfig"
    },
    "subjectId": {
      "type": "string"
    }
  },
  "definitions": {
    "CivicProfile": {
      "type": "object",
      "required": [
        "agency",
        "integrity",
        "resonance",
        "viability"
      ],
      "properties": {
        "agency": {
          "type": "number",
          "format": "double"
        },
        "integrity": {
          "type": "number",
          "format": "double"
        },
        "resonance": {
          "type": "number",
          "format": "double"
        },
        "viability": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "ExternalIssuerConfig": {
      "type": "object",
      "required": [
        "active",
        "issuerId",
        "issuerType",
        "uniquenessSaltId"
      ],
      "properties": {
        "active": {
          "type": "boolean"
        },
        "expectedClientId": {
          "type": [
            "string",
            "null"
          ]
        },
        "issuerId": {
          "type": "string"
        },
        "issuerType": {
          "$ref": "#/definitions/IssuerType"
        },
        "jwksUri": {
          "type": [
            "string",
            "null"
          ]
        },
        "oidcIssuerUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "uniquenessSaltId": {
          "type": "string"
        },
        "vcDid": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "IssuerType": {
      "type": "string",
      "enum": [
        "bank",
        "hospital",
        "university",
        "gov",
        "other"
      ]
    }
  }
}