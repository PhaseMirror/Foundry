{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ValidatedIdToken",
  "type": "object",
  "required": [
    "audience",
    "claims",
    "expiresAt",
    "issuedAt",
    "issuer",
    "subject"
  ],
  "properties": {
    "audience": {
      "type": "string"
    },
    "claims": true,
    "expiresAt": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "issuedAt": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "issuer": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    }
  }
}