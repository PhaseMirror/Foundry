{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifiedVerifiableCredential",
  "type": "object",
  "required": [
    "claims",
    "issuanceDate",
    "issuerDid",
    "subjectDid",
    "type"
  ],
  "properties": {
    "claims": true,
    "expirationDate": {
      "type": [
        "string",
        "null"
      ]
    },
    "issuanceDate": {
      "type": "string"
    },
    "issuerDid": {
      "type": "string"
    },
    "subjectDid": {
      "type": "string"
    },
    "type": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}