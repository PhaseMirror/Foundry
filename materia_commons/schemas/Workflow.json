{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workflow",
  "type": "object",
  "required": [
    "name",
    "tasks"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Task"
      }
    },
    "trust": {
      "anyOf": [
        {
          "$ref": "#/definitions/TrustLevel"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "Task": {
      "type": "object",
      "required": [
        "action",
        "id"
      ],
      "properties": {
        "action": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "server_binding": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "TrustLevel": {
      "type": "string",
      "enum": [
        "internal",
        "external"
      ]
    }
  }
}