@misc{FlomUOR2025Atlas,
    author       = {Alex Flom and The UOR Foundation},
    title        = {Atlas of Resonance Classes: A First-Principles Construction of Exceptional Lie Groups},
    howpublished = {GitHub repository},
    year         = {2025},
    url          = {https://github.com/The-UOR-Foundation-Archive/atlas-embeddings},
    note         = {The atlas-embeddings framework demonstrates how all five exceptional Lie groups (G₂, F₄, E₆, E₇, E₈) emerge from a single 96-vertex construct via categorical operations. The complete embedding from Atlas into E₈ is known as the Golden Seed Vector. The repository includes a Lean 4 formalization (8 modules, 1,454 lines, 54 theorems, 0 sorrys) and exact arithmetic with no floating point.}
}

@misc{FlomUOR2025GoldenSeed,
    author       = {Alex Flom and The UOR Foundation},
    title        = {The Golden Seed Vector: A Universal Mathematical Language},
    howpublished = {UOR Foundation Research Announcement},
    year         = {2025},
    url          = {https://johncandeto.com/information-flow/research-uor-foundation-universal-object-reference},
    note         = {Announces the discovery of a universal mathematical language derived from the Atlas of Resonance Classes. The Golden Seed Vector is a 96-dimensional configuration in the 240-vertex E₈ root system that encodes the full exceptional group hierarchy.}
}

@misc{UORFoundation2025Hologram,
    author       = {{UOR Foundation}},
    title        = {Hologram: Hyperdimensional Computing Framework},
    howpublished = {UOR Foundation Project},
    year         = {2025},
    note         = {The Hologram framework builds upon the Atlas discovery to create hyperdimensional computing (HDC) systems that can process any type of data with zero information loss. It leverages the exceptional Lie group symmetries derived from the Atlas for structured embedding spaces. Further details are available in the UOR Foundation repositories.}
}

@misc{UORFoundation2025C768,
    author       = {{UOR Foundation}},
    title        = {C768: Prism Cryptographic Substrate},
    howpublished = {UOR Foundation Project},
    year         = {2025},
    note         = {C768 is a cryptographic substrate within the UOR Foundation's Prism ecosystem. It provides hashing, curve, signature, and commitment axes bound to FIPS-180-4 / FIPS-2 standards. The C768 module is part of the uor-prism-crypto crate and is defined in ADR-031 of the UOR Framework wiki.}
}

@misc{UORFoundation2025F1,
    author       = {{UOR Foundation}},
    title        = {F1: Field with One Element — Arithmetic Surface for the Riemann Hypothesis},
    howpublished = {UOR Foundation Research Program},
    year         = {2025},
    note         = {The F1 (Field with One Element) program extends the Atlas framework to the arithmetic of the Riemann zeta function. It constructs the F1-square (Spec ℤ ×_{F₁} Spec ℤ) as a blueprint for the Hodge index theorem, providing a path toward a proof of the Riemann Hypothesis. This work builds on the categorical operations developed in the Atlas embeddings.}
}

@misc{FlomUOR2025Prism,
